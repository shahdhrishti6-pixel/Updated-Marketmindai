{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's profile photo."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User's role in the application."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the profile was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ZapierConfig": {
      "title": "Zapier Configuration",
      "description": "Stores Zapier webhook URLs and settings for a user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Owner of the configuration."
        },
        "integrationId": {
          "type": "string",
          "description": "ID of the integration (e.g., zapier-leads)."
        },
        "webhookUrl": {
          "type": "string",
          "description": "The Zapier webhook URL."
        },
        "autoSync": {
          "type": "boolean",
          "description": "Whether auto-sync is enabled."
        },
        "lastTriggered": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the webhook was triggered."
        }
      },
      "required": ["uid", "integrationId", "webhookUrl", "autoSync"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{userId}/integrations/{integrationId}": {
      "schema": "ZapierConfig",
      "description": "User-specific Zapier configurations."
    }
  }
}
